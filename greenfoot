#!/bin/bash
set -euo pipefail

GREENFOOT_HOME="/opt/greenfoot"
JAVA="${GREENFOOT_HOME}/jdk/bin/java"
JAVAFX_HOME="${GREENFOOT_HOME}/javafx"

# Build classpath: boot.jar + all JavaFX JARs
CP="${GREENFOOT_HOME}/lib/boot.jar"
for j in "${JAVAFX_HOME}/lib"/javafx*.jar; do
  CP="${CP}:${j}"
done

# Optional: graphics workarounds
#   PRISM_ORDER=sw   -> software rendering
#   GDK_BACKEND=x11  -> force X11 (instead of Wayland)
env_args=()
if [[ -n "${GDK_BACKEND:-}" ]]; then
  env_args+=("GDK_BACKEND=$GDK_BACKEND")
fi

java_args=()
if [[ -n "${PRISM_ORDER:-}" ]]; then
  java_args+=("-Dprism.order=$PRISM_ORDER")
fi

exec env "${env_args[@]}" \
  "${JAVA}" \
  -Xmx512M \
  -Dawt.useSystemAAFontSettings=on \
  -Djavafx.embed.singleThread=true \
  "${java_args[@]}" \
  -cp "${CP}" \
  bluej.Boot \
  -greenfoot=true \
  -bluej.compiler.showunchecked=false \
  -javafxpath="${JAVAFX_HOME}" \
  "$@"